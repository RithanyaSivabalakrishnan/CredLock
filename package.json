{
  "name": "secure-payment-vault",
  "version": "1.0.0",
  "description": "OS-inspired sandboxed payment vault Chrome extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build":       "node build.mjs",
    "build:watch": "node build.mjs --watch",
    "test":        "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit":   "jest tests/unit",
    "test:e2e":    "jest tests/integration",
    "lint":        "eslint src/**/*.js"
  },
  "devDependencies": {
    "esbuild":         "^0.20.0",
    "jest":            "^29.0.0",
    "eslint":          "^8.0.0"
  }
}
